<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- ========================= -->
    <!-- Website Course Catalog -->
    <!-- ========================= -->
    <template id="course_catalog_page" name="LMS Course Catalog">
        <t t-call="website.layout">
            <div class="container">
                <h1>Course Catalog</h1>
                <p>This is the course catalog page.</p>
            </div>
        </t>
    </template>

    <!-- ========================= -->
    <!-- Course Search View -->
    <!-- ========================= -->
    <record id="view_course_search" model="ir.ui.view">
        <field name="name">lms.course.search</field>
        <field name="model">lms.course</field>
        <field name="arch" type="xml">
            <search string="Search Courses">
                <field name="name"
                       string="Course"
                       filter_domain="['|', '|',
                           ('name', 'ilike', self),
                           ('description', 'ilike', self),
                           ('category', 'ilike', self)]"/>
                <filter string="Active"
                        name="active"
                        domain="[('active','=',True)]"/>
                <group expand="0" string="Group By">
                    <filter string="Category"
                            name="group_by_category"
                            context="{'group_by': 'category'}"/>
                </group>
            </search>
        </field>
    </record>

<template id="course_catalog" name="LMS – Course Catalog">
    <t t-call="website.layout">
        <div class="o_container_small py-5">

            <h1 class="mb-3">Course Catalog</h1>

            <form method="get" action="/lms/courses" class="d-flex flex-wrap gap-2 mb-4">
                <input type="text" name="search" class="form-control w-auto" placeholder="Search…" t-att-value="search"/>
                <select name="category" class="form-select w-auto">
                    <option value="">All Categories</option>
                    <t t-foreach="categories" t-as="cat">
                        <option t-att-value="cat[0]" t-att-selected="cat[0] == selected_category"><t t-out="cat[1]"/></option>
                    </t>
                </select>
                <select name="difficulty" class="form-select w-auto">
                    <option value="">All Levels</option>
                    <t t-foreach="difficulties" t-as="diff">
                        <option t-att-value="diff[0]" t-att-selected="diff[0] == selected_difficulty"><t t-out="diff[1]"/></option>
                    </t>
                </select>
                <button type="submit" class="btn btn-primary">Filter</button>
                <a href="/lms/courses" class="btn btn-outline-secondary">Clear</a>
            </form>

            <p class="text-muted small mb-3"><t t-out="len(courses)"/> course(s) found</p>

            <t t-if="courses">
                <div class="row row-cols-1 row-cols-md-3 g-4">
                    <t t-foreach="courses" t-as="course">
                        <div class="col">
                            <div class="card h-100">
                                <t t-if="course.image">
                                    <img t-attf-src="/web/image/lms.course/#{course.id}/image"
                                         class="card-img-top" style="height:150px;object-fit:cover;"
                                         t-att-alt="course.name"/>
                                </t>
                                <div class="card-body">
                                    <span t-att-class="'badge mb-1 lms-badge--' + course.difficulty">
                                        <t t-out="course.difficulty.capitalize()"/>
                                    </span>
                                    <h5 class="card-title">
                                        <a t-attf-href="/lms/courses/#{course.id}"
                                           class="stretched-link text-dark text-decoration-none">
                                            <t t-out="course.name"/>
                                        </a>
                                    </h5>
                                    <p class="card-text text-muted small">
                                        <t t-out="course.instructor_id.name"/> —
                                        <t t-out="'%.0f' % course.duration_hours"/>h —
                                        <t t-out="course.enrollment_count"/> enrolled
                                    </p>
                                </div>
                                <div class="card-footer d-flex justify-content-between align-items-center">
                                    <t t-if="course.id in enrolled_course_ids">
                                        <span class="badge bg-success">Enrolled</span>
                                        <a t-attf-href="/lms/courses/#{course.id}" class="btn btn-sm btn-outline-primary">Continue</a>
                                    </t>
                                    <t t-else="">
                                        <span class="text-success fw-bold">Free</span>
                                        <a t-attf-href="/lms/courses/#{course.id}" class="btn btn-sm btn-primary">Enroll</a>
                                    </t>
                                </div>
                            </div>
                        </div>
                    </t>
                </div>
            </t>
            <t t-else="">
                <p class="text-center text-muted py-5">No courses match your filters.</p>
            </t>

        </div>
    </t>
</template>

<template id="course_detail" name="LMS – Course Detail">
    <t t-call="website.layout">
        <div class="o_container_small py-5">

            <a href="/lms/courses" class="text-muted small d-block mb-3">Back to catalog</a>

            <div class="row g-4">
                <div class="col-md-8">
                    <span t-att-class="'badge mb-2 lms-badge--' + course.difficulty">
                        <t t-out="course.difficulty.capitalize()"/>
                    </span>
                    <h1 class="h2 mt-1"><t t-out="course.name"/></h1>
                    <p class="text-muted small">
                        <t t-out="course.instructor_id.name"/> —
                        <t t-out="'%.0f' % course.duration_hours"/>h —
                        <t t-out="course.enrollment_count"/> students
                    </p>
                    <div class="mt-3" t-out="course.description"/>
                </div>

                <div class="col-md-4">
                    <div class="card">
                        <t t-if="course.image">
                            <img t-attf-src="/web/image/lms.course/#{course.id}/image"
                                 class="card-img-top" style="height:150px;object-fit:cover;"
                                 t-att-alt="course.name"/>
                        </t>
                        <div class="card-body">
                            <p class="fs-5 fw-bold text-success mb-3">Free</p>
                            <t t-if="enrollment">
                                <span class="badge bg-success mb-2">Enrolled</span>
                                <div class="progress mb-1" style="height:5px">
                                    <div class="progress-bar bg-success" t-attf-style="width:#{enrollment.progress}%"/>
                                </div>
                                <p class="text-muted small"><t t-out="'%.0f' % enrollment.progress"/>% complete</p>
                            </t>
                            <t t-else="">
                                <form t-attf-action="/lms/courses/#{course.id}/enroll" method="post">
                                    <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                    <button class="btn btn-primary w-100">Enroll for Free</button>
                                </form>
                            </t>
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </t>
</template>


</odoo>
