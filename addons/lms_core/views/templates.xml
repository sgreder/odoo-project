    <template id="lms_dashboard" name="LMS Dashboard">
        <t t-call="website.layout">

            <div class="container mt-5">

                <!-- HEADER -->
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h2 class="mb-0">LMS Dashboard</h2>
                    <span class="text-muted">
                        <t t-esc="request.env.user.name"/>
                    </span>
                </div>
                
            <!-- ========================= -->
            <!-- SEARCH USERS -->
            <!-- ========================= -->

            <div class="mb-5">
                <h4 class="mb-3">🔍 Search Users</h4>

                <form action="/lms/search" method="get" class="row g-2">

                    <div class="col-md-10">
                        <input type="text"
                               name="query"
                               class="form-control"
                               placeholder="Search by name or email"/>
                    </div>

                    <div class="col-md-2">
                        <button type="submit" class="btn btn-primary w-100">
                            Search
                        </button>
                    </div>

                </form>
            </div>


                <!-- ========================= -->
                <!-- STUDENT SECTION -->
                <!-- ========================= -->

                <!-- Uncomment later -->
                <!-- <t t-if="request.env.user.is_student"> -->

                <div class="mb-5">
                    <h4 class="mb-3">🎓 Student Dashboard</h4>

                    <div class="row">

                        <!-- My Courses -->
                        <div class="col-md-4">
                            <div class="lms-card">
                                <h5>📚 My Courses</h5>
                                <p>List of enrolled courses</p>

                                <ul>
                                    <li>Course 1 - 60% complete</li>
                                    <li>Course 2 - 30% complete</li>
                                    <li>Course 3 - 90% complete</li>
                                </ul>

                            </div>
                        </div>

                        <!-- Progress Summary -->
                        <div class="col-md-4">
                            <div class="lms-card">
                                <h5>📊 Progress Summary</h5>
                                <p>Overall progress across courses</p>

                                <ul>
                                    <li>Course 1: 60%</li>
                                    <li>Course 2: 30%</li>
                                    <li>Course 3: 90%</li>
                                </ul>

                                <p><strong>Overall:</strong> 60%</p>
                            </div>
                        </div>

                        <!-- Certificates -->
                        <div class="col-md-4">
                            <div class="lms-card">
                                <h5>🏆 Certificates</h5>
                                <p>Earned certifications</p>

                                <ul>
                                    <li>Python Basics Certificate</li>
                                    <li>Web Dev Certificate</li>
                                </ul>
                            </div>
                        </div>

                    </div>

                    <!-- Quick Actions -->
                    <div class="mt-3">
                        <a href="/lms/courses" class="btn btn-primary btn-sm me-2">
                            Continue Course
                        </a>
                        <a href="/lms/courses" class="btn btn-outline-primary btn-sm">
                            View All Courses
                        </a>
                    </div>
                </div>

                <!-- </t> -->



                <!-- ========================= -->
                <!-- 🧑INSTRUCTOR SECTION -->
                <!-- ========================= -->

                <!-- Uncomment later -->
                <!-- <t t-if="request.env.user.is_instructor"> -->

                <div class="mb-5">
                    <h4 class="mb-3">🧑‍🏫 Instructor Dashboard</h4>

                    <div class="row">

                        <!-- Courses Teaching -->
                        <div class="col-md-4">
                            <div class="lms-card">
                                <h5>📚 My Courses</h5>
                                <p>Courses you created</p>

                                <ul>
                                    <li>Intro to Python</li>
                                    <li>Advanced Web Dev</li>
                                </ul>
                            </div>
                        </div>

                        <!-- Students -->
                        <div class="col-md-4">
                            <div class="lms-card">
                                <h5>👥 Students</h5>
                                <p>Enrollment overview</p>

                                <ul>
                                    <li>Python: 25 students</li>
                                    <li>Web Dev: 18 students</li>
                                </ul>
                            </div>
                        </div>

                        <!-- Course Performance -->
                        <div class="col-md-4">
                            <div class="lms-card">
                                <h5>📊 Performance</h5>
                                <p>Course completion stats</p>

                                <ul>
                                    <li>Python: 70% completion</li>
                                    <li>Web Dev: 55% completion</li>
                                </ul>
                            </div>
                        </div>

                    </div>

                    <!-- Quick Actions -->
                    <div class="mt-3">
                        <a href="/lms/create-course" class="btn btn-success btn-sm me-2">
                            Create New Course
                        </a>
                        <a href="/lms/manage-courses" class="btn btn-outline-success btn-sm">
                            Manage Courses
                        </a>
                    </div>
                </div>

                <!-- </t> -->

            </div>

        </t>
    </template>

    <!-- ========================= -->
    <!-- SEARCH RESULT PAGE -->
    <!-- ========================= -->
    <template id="search_results" name="Search Results">
        <t t-call="website.layout">

            <div class="container mt-5">
                <h2>Search Results</h2>

                <p>
                    You searched for:
                    <strong t-esc="query"/>
                </p>

                <t t-if="users">
                    <ul>
                        <t t-foreach="users" t-as="user">
                            <li>
                                <span t-esc="user.name"/> -
                                <span t-esc="user.login"/>
                            </li>
                        </t>
                    </ul>
                </t>

                <t t-else="">
                    <p>No users found.</p>
                </t>
            </div>

        </t>
    </template>


    <!-- ========================= -->
    <!-- LOGIN PAGE -->
    <!-- ========================= -->
    <template id="login_template" name="LMS Login">
        <t t-call="website.layout">

            <div class="container mt-5" style="max-width: 400px;">
                <h2 class="mb-4 text-center">LMS Login</h2>

                <!-- ERROR MESSAGE -->
                <t t-if="error">
                    <div class="alert alert-danger">
                        <t t-esc="error"/>
                    </div>
                </t>

                <form action="/lms/login/submit" method="post">

                    <!-- CSRF TOKEN -->
                    <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>

                    <!-- EMAIL -->
                    <div class="mb-3">
                        <label>Email</label>
                        <input type="text" name="login"
                               t-att-value="login or ''"
                               t-att-class="'form-control ' + ('is-invalid' if error else '')"
                               required="required"/>
                    </div>

                    <!-- PASSWORD -->
                    <div class="mb-3">
                        <label>Password</label>
                        <input type="password" name="password"
                               t-att-class="'form-control ' + ('is-invalid' if error else '')"
                               required="required"/>
                    </div>

                    <!-- BUTTON -->
                    <button type="submit" class="btn btn-primary w-100">
                        Login
                    </button>

                </form>

                <!-- LINK TO SIGNUP -->
                <div class="text-center mt-3">
                    <a href="/lms/signup">Don't have an account? Sign up</a>
                </div>

            </div>

        </t>
    </template>


    <!-- ========================= -->
    <!-- SIGNUP PAGE -->
    <!-- ========================= -->
    <template id="signup_template" name="LMS Signup">
        <t t-call="website.layout">

            <div class="container mt-5" style="max-width: 400px;">
                <h2 class="mb-4 text-center">LMS Signup</h2>

                <!-- ERROR MESSAGE -->
                <t t-if="error">
                    <div class="alert alert-danger">
                        <t t-esc="error"/>
                    </div>
                </t>

                <form action="/lms/signup/submit" method="post">

                    <!-- CSRF TOKEN -->
                    <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>

                    <!-- USERNAME -->
                    <div class="mb-3">
                        <label>Username</label>
                        <input type="text" name="username"
                               t-att-value="username or ''"
                               t-att-class="'form-control ' + ('is-invalid' if error else '')"
                               placeholder="Enter username"
                               required="required"/>
                    </div>

                    <!-- EMAIL -->
                    <div class="mb-3">
                        <label>Email</label>
                        <input type="text" name="email"
                               t-att-value="email or ''"
                               t-att-class="'form-control ' + ('is-invalid' if error else '')"
                               required="required"/>
                    </div>

                    <!-- PASSWORD -->
                    <div class="mb-3">
                        <label>Password</label>
                        <input type="password" name="password"
                               t-att-class="'form-control ' + ('is-invalid' if error else '')"
                               placeholder="At least 8 chars, 1 letter and 1 number"
                               required="required"/>
                    </div>

                    <!-- BUTTON -->
                    <button type="submit" class="btn btn-success w-100">
                        Sign Up
                    </button>

                </form>

                <!-- LINK TO LOGIN -->
                <div class="text-center mt-3">
                    <a href="/lms/login">Already have an account? Login</a>
                </div>

            </div>

        </t>
    </template>


    <!-- ========================= -->
    <!-- PROFILE PAGE -->
    <!-- ========================= -->
    <template id="profile_template" name="LMS Profile">
        <t t-call="website.layout">

            <div class="container mt-5" style="max-width: 600px;">

                <h2 class="mb-4">👤 My Profile</h2>

                <div class="lms-card p-4">

                    <div class="mb-3">
                        <strong>Name:</strong>
                        <span t-esc="profile['basic_info']['name']"/>
                    </div>

                    <div class="mb-3">
                        <strong>Email:</strong>
                        <span t-esc="profile['basic_info']['email']"/>
                    </div>

                    <div class="mb-3">
                        <strong>Bio:</strong>
                        <span t-esc="profile['basic_info']['bio'] or '—'"/>
                    </div>

                    <div class="mb-3">
                        <strong>Experience Level:</strong>
                        <span t-esc="profile['basic_info']['experience_level'] or '—'"/>
                    </div>

                    <div class="mb-3">
                        <strong>Rating:</strong>
                        <span t-esc="profile['basic_info']['rating']"/>
                    </div>

                    <div class="mb-3">
                        <strong>Roles:</strong>
                        <t t-if="profile['roles']">
                            <span t-esc="', '.join(profile['roles'])"/>
                        </t>
                        <t t-else="">
                            <span>—</span>
                        </t>
                    </div>

                </div>

                <div class="mt-3">
                    <a href="/lms/dashboard" class="btn btn-outline-primary btn-sm">
                        Back to Dashboard
                    </a>
                </div>

            </div>

        </t>
    </template>

</odoo>
