    <template id="lms_dashboard" name="LMS Dashboard">
        <t t-call="website.layout">

            <div class="container mt-5">

                <!-- HEADER -->
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h2 class="mb-0">LMS Dashboard</h2>

                    <a t-att-href="'/lms/user/%s' % request.env.user.id"
                        class="text-muted">

                        <t t-esc="request.env.user.name"/>

                    </a>
                </div>
                
            <!-- ========================= -->
            <!-- SEARCH USERS -->
            <!-- ========================= -->

            <div class="mb-5">
                <h4 class="mb-3">🔍 Search Users</h4>

                <form action="/lms/search" method="get" class="row g-2">

                    <div class="col-md-10">
                        <input type="text"
                               name="query"
                               class="form-control"
                               placeholder="Search by name or email"/>
                    </div>

                    <div class="col-md-2">
                        <button type="submit" class="btn btn-primary w-100">
                            Search
                        </button>
                    </div>

                </form>
            </div>


                <!-- ========================= -->
                <!-- STUDENT SECTION -->
                <!-- ========================= -->

                <!-- Uncomment later -->
                <!-- <t t-if="request.env.user.is_student"> -->

                <div class="mb-5">
                    <h4 class="mb-3">🎓 Student Dashboard</h4>

                    <div class="row">

                        <!-- My Courses -->
                        <div class="col-md-4">
                            <div class="lms-card">
                                <h5>📚 My Courses</h5>
                                <p>List of enrolled courses</p>

                                <ul>
                                    <li>Course 1 - 60% complete</li>
                                    <li>Course 2 - 30% complete</li>
                                    <li>Course 3 - 90% complete</li>
                                </ul>

                            </div>
                        </div>

                        <!-- Progress Summary -->
                        <div class="col-md-4">
                            <div class="lms-card">
                                <h5>📊 Progress Summary</h5>
                                <p>Overall progress across courses</p>

                                <ul>
                                    <li>Course 1: 60%</li>
                                    <li>Course 2: 30%</li>
                                    <li>Course 3: 90%</li>
                                </ul>

                                <p><strong>Overall:</strong> 60%</p>
                            </div>
                        </div>

                        <!-- Certificates -->
                        <div class="col-md-4">
                            <div class="lms-card">
                                <h5>🏆 Certificates</h5>
                                <p>Earned certifications</p>

                                <ul>
                                    <li>Python Basics Certificate</li>
                                    <li>Web Dev Certificate</li>
                                </ul>
                            </div>
                        </div>

                    </div>

                    <!-- Quick Actions -->
                    <div class="mt-3">
                        <a href="/lms/courses" class="btn btn-primary btn-sm me-2">
                            Continue Course
                        </a>
                        <a href="/lms/courses" class="btn btn-outline-primary btn-sm">
                            View All Courses
                        </a>
                    </div>
                </div>

                <!-- </t> -->



                <!-- ========================= -->
                <!-- 🧑INSTRUCTOR SECTION -->
                <!-- ========================= -->

                <!-- Uncomment later -->
                <!-- <t t-if="request.env.user.is_instructor"> -->

                <div class="mb-5">
                    <h4 class="mb-3">🧑‍🏫 Instructor Dashboard</h4>

                    <div class="row">

                        <!-- Courses Teaching -->
                        <div class="col-md-4">
                            <div class="lms-card">
                                <h5>📚 My Courses</h5>
                                <p>Courses you created</p>

                                <ul>
                                    <li>Intro to Python</li>
                                    <li>Advanced Web Dev</li>
                                </ul>
                            </div>
                        </div>

                        <!-- Students -->
                        <div class="col-md-4">
                            <div class="lms-card">
                                <h5>👥 Students</h5>
                                <p>Enrollment overview</p>

                                <ul>
                                    <li>Python: 25 students</li>
                                    <li>Web Dev: 18 students</li>
                                </ul>
                            </div>
                        </div>

                        <!-- Course Performance -->
                        <div class="col-md-4">
                            <div class="lms-card">
                                <h5>📊 Performance</h5>
                                <p>Course completion stats</p>

                                <ul>
                                    <li>Python: 70% completion</li>
                                    <li>Web Dev: 55% completion</li>
                                </ul>
                            </div>
                        </div>

                    </div>

                    <!-- Quick Actions -->
                    <div class="mt-3">
                        <a href="/lms/create-course" class="btn btn-success btn-sm me-2">
                            Create New Course
                        </a>
                        <a href="/lms/manage-courses" class="btn btn-outline-success btn-sm">
                            Manage Courses
                        </a>
                    </div>
                </div>

                <!-- </t> -->

            </div>

        </t>
    </template>

    <!-- ========================= -->
    <!-- SEARCH RESULT PAGE -->
    <!-- ========================= -->
    <template id="search_results" name="Search Results">
        <t t-call="website.layout">

            <div class="container mt-5">
                <h2>Search Results</h2>

                <p>
                    You searched for:
                    <strong t-esc="query"/>
                </p>

                <t t-if="users">
                    <ul>
                        <t t-foreach="users" t-as="user">
                            <li>
                                <a t-att-href="'/lms/user/%s' % user.id">
                                    <span t-esc="user.name"/>
                                    -
                                    <span t-esc="user.login"/>
                                </a>
                            </li>
                        </t>
                    </ul>
                </t>

                <t t-else="">
                    <p>No users found.</p>
                </t>
            </div>

        </t>
    </template>

    <!-- ========================= -->
    <!-- USER PROFILE PAGE -->
    <!-- ========================= -->
    <template id="user_profile" name="User Profile">
        <t t-call="website.layout">

            <div class="container mt-5">

                <h2>User Profile</h2>

                <div class="card p-4">

                    <h4 t-esc="profile_user.name"/>

                    <p>
                        <strong>Email:</strong>
                        <span t-esc="profile_user.login"/>
                    </p>

                    <p>
                        <strong>Bio:</strong>
                        <span t-esc="profile_user.bio or 'No bio available'"/>
                    </p>

                    <p>
                        <strong>Experience Level:</strong>
                        <span t-esc="profile_user.experience_level or 'Not set'"/>
                    </p>

                    <p>
                        <strong>Role:</strong>
                        <t t-if="profile_user.is_student">Student</t>
                        <t t-if="profile_user.is_instructor">Instructor</t>
                        <t t-if="profile_user.is_admin">Admin</t>
                    </p>

                    <p>
                        <strong>Rating:</strong>
                        <span t-esc="profile_user.rating or 0"/> ⭐
                        (<span t-esc="profile_user.rating_count or 0"/> ratings)
                    </p>

                </div>

                <div class="mt-4 d-flex gap-2">

                    <!-- RATE BUTTON -->
                    <a t-att-href="'/lms/user/%s/rate' % profile_user.id"
                        class="btn btn-warning">
                        ⭐ Rate this user
                    </a>

                    <!-- EDIT BUTTON -->
                    <t t-if="request.env.user.id == profile_user.id">
                        <a t-att-href="'/lms/user/%s/edit' % profile_user.id"
                            class="btn btn-primary">
                            Edit Profile
                        </a>
                    </t>

                    <!-- BACK BUTTON -->
                    <a href="/lms/dashboard" class="btn btn-secondary">
                        Back
                    </a>

                </div>

            </div>

        </t>
    </template>

    <!-- ========================= -->
    <!-- EDIT USER PAGE -->
    <!-- ========================= -->
        <template id="edit_user_profile" name="Edit User Profile">
        <t t-call="website.layout">

            <div class="container mt-5" style="max-width: 700px;">

                <h2>Edit Profile</h2>

                <t t-if="error">
                    <div class="alert alert-danger">
                        <t t-esc="error"/>
                    </div>
                </t>

                <div class="card p-4">
                    <form t-att-action="'/lms/user/%s/edit' % profile_user.id" method="post">

                        <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>

                        <div class="mb-3">
                            <label>Name</label>
                            <input type="text"
                                   name="name"
                                   class="form-control"
                                   t-att-value="profile_user.name or ''"/>
                        </div>

                        <div class="mb-3">
                            <label>Email</label>
                            <input type="email"
                                   name="login"
                                   class="form-control"
                                   t-att-value="profile_user.login or ''"/>
                        </div>

                        <div class="mb-3">
                            <label>Bio</label>
                            <textarea name="bio"
                                      class="form-control"
                                      rows="4"><t t-esc="profile_user.bio or ''"/></textarea>
                        </div>

                        <div class="mb-3">
                            <label>Experience Level</label>
                            <select name="experience_level" class="form-control">
                                <option value="">Select experience level</option>
                                <option value="beginner"
                                        t-att-selected="'selected' if profile_user.experience_level == 'beginner' else None">
                                    Beginner
                                </option>
                                <option value="intermediate"
                                        t-att-selected="'selected' if profile_user.experience_level == 'intermediate' else None">
                                    Intermediate
                                </option>
                                <option value="advanced"
                                        t-att-selected="'selected' if profile_user.experience_level == 'advanced' else None">
                                    Advanced
                                </option>
                            </select>
                        </div>

                        <div class="mb-3 form-check">
                            <input type="checkbox"
                                   name="is_student"
                                   class="form-check-input"
                                   value="1"
                                   t-att-checked="'checked' if profile_user.is_student else None"/>
                            <label class="form-check-label">Student</label>
                        </div>

                        <div class="mb-3 form-check">
                            <input type="checkbox"
                                   name="is_instructor"
                                   class="form-check-input"
                                   value="1"
                                   t-att-checked="'checked' if profile_user.is_instructor else None"/>
                            <label class="form-check-label">Instructor</label>
                        </div>

                        <div class="mb-3 form-check">
                            <input type="checkbox"
                                   name="is_admin"
                                   class="form-check-input"
                                   value="1"
                                   t-att-checked="'checked' if profile_user.is_admin else None"/>
                            <label class="form-check-label">Admin</label>
                        </div>

                        <div class="mb-3">
                            <label>Rating</label>
                            <input type="text"
                                   class="form-control"
                                   t-att-value="profile_user.rating or 0"
                                   readonly="readonly"/>
                        </div>

                        <div class="mb-3">
                            <label>Total Ratings</label>
                            <input type="text"
                                   class="form-control"
                                   t-att-value="profile_user.rating_count or 0"
                                   readonly="readonly"/>
                        </div>

                        <button type="submit" class="btn btn-success">
                            Save Changes
                        </button>

                        <a t-att-href="'/lms/user/%s' % profile_user.id"
                           class="btn btn-secondary ms-2">
                            Cancel
                        </a>

                    </form>
                </div>

            </div>

        </t>
    </template>

    <!-- ========================= -->
    <!-- USER RATING PAGE -->
    <!-- ========================= -->
    <template id="user_rate_page" name="Rate User">
        <t t-call="website.layout">

            <div class="container mt-5" style="max-width: 500px;">

                <h3>Rate <t t-esc="profile_user.name"/></h3>

                <!-- SHOW EXISTING RATING -->
                <t t-set="existing_rating"
                    t-value="request.env['lms.user.rating'].sudo().search([
                        ('rater_id', '=', request.env.user.id),
                        ('rated_user_id', '=', profile_user.id)
                    ], limit=1)"/>

                <t t-if="existing_rating">
                    <div class="alert alert-info">
                        You previously rated this user:
                        <strong t-esc="existing_rating.rating"/> ⭐
                    </div>
                </t>

                <form action="/lms/user/rate" method="post">

                    <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                    <input type="hidden" name="user_id" t-att-value="profile_user.id"/>

                    <div class="mb-3">
                        <label>Select Rating:</label>

                        <select name="rating" class="form-control">

                            <option value="1">⭐</option>
                            <option value="2">⭐⭐</option>
                            <option value="3">⭐⭐⭐</option>
                            <option value="4">⭐⭐⭐⭐</option>
                            <option value="5">⭐⭐⭐⭐⭐</option>

                        </select>

                    </div>

                    <button type="submit" class="btn btn-primary w-100">
                        Submit Rating
                    </button>

                </form>

                <div class="mt-3 text-center">
                    <a t-att-href="'/lms/user/%s' % profile_user.id">
                        ← Back to Profile
                    </a>
                </div>

            </div>

        </t>
    </template>


    <!-- ========================= -->
    <!-- LOGIN PAGE -->
    <!-- ========================= -->
    <template id="login_template" name="LMS Login">
        <t t-call="website.layout">

            <div class="container mt-5" style="max-width: 400px;">
                <h2 class="mb-4 text-center">LMS Login</h2>

                <!-- ERROR MESSAGE -->
                <t t-if="error">
                    <div class="alert alert-danger">
                        <t t-esc="error"/>
                    </div>
                </t>

                <form action="/lms/login/submit" method="post">

                    <!-- CSRF TOKEN -->
                    <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>

                    <!-- EMAIL -->
                    <div class="mb-3">
                        <label>Email</label>
                        <input type="text" name="login"
                               t-att-value="login or ''"
                               t-att-class="'form-control ' + ('is-invalid' if error else '')"
                               required="required"/>
                    </div>

                    <!-- PASSWORD -->
                    <div class="mb-3">
                        <label>Password</label>
                        <input type="password" name="password"
                               t-att-class="'form-control ' + ('is-invalid' if error else '')"
                               required="required"/>
                    </div>

                    <!-- BUTTON -->
                    <button type="submit" class="btn btn-primary w-100">
                        Login
                    </button>

                </form>

                <!-- LINK TO SIGNUP -->
                <div class="text-center mt-3">
                    <a href="/lms/signup">Don't have an account? Sign up</a>
                </div>

            </div>

        </t>
    </template>


    <!-- ========================= -->
    <!-- SIGNUP PAGE -->
    <!-- ========================= -->
    <template id="signup_template" name="LMS Signup">
        <t t-call="website.layout">

            <div class="container mt-5" style="max-width: 400px;">
                <h2 class="mb-4 text-center">LMS Signup</h2>

                <!-- ERROR MESSAGE -->
                <t t-if="error">
                    <div class="alert alert-danger">
                        <t t-esc="error"/>
                    </div>
                </t>

                <form action="/lms/signup/submit" method="post">

                    <!-- CSRF TOKEN -->
                    <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>

                    <!-- USERNAME (not used yet) -->
                    <div class="mb-3">
                        <label>Username</label>
                        <input type="text" name="username"
                               class="form-control"
                               placeholder="Enter username"/>
                    </div>

                    <!-- EMAIL -->
                    <div class="mb-3">
                        <label>Email</label>
                        <input type="text" name="email"
                               t-att-value="email or ''"
                               t-att-class="'form-control ' + ('is-invalid' if error else '')"
                               required="required"/>
                    </div>

                    <!-- PASSWORD (not used yet) -->
                    <div class="mb-3">
                        <label>Password</label>
                        <input type="password" name="password"
                               class="form-control"
                               placeholder="Enter password"/>
                    </div>

                    <!-- BUTTON -->
                    <button type="submit" class="btn btn-success w-100">
                        Sign Up
                    </button>

                </form>

                <!-- LINK TO LOGIN -->
                <div class="text-center mt-3">
                    <a href="/lms/login">Already have an account? Login</a>
                </div>

            </div>

        </t>
    </template>

</odoo>
